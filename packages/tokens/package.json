{
  "name": "@nextouch-app/mochi-tokens",
  "version": "0.2.0",
  "description": "Design tokens for Mochi UI",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./src/tokens.css",
    "./tokens.json": "./src/tokens.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "clean": "rimraf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nextouch-app/mochi-ui.git",
    "directory": "packages/tokens"
  },
  "homepage": "https://nextouch-app.github.io/mochi-ui/",
  "bugs": {
    "url": "https://github.com/nextouch-app/mochi-ui/issues"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
